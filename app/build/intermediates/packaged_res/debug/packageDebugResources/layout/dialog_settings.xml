<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FFFFFF">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="JKS签名配置"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/llCustomJksForm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <EditText android:id="@+id/etJksPath" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="JKS文件路径" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etJksStorePass" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Store密码" android:inputType="textPassword" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etJksAlias" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="别名" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etJksKeyPass" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Key密码" android:inputType="textPassword" android:layout_marginBottom="8dp"/>
            </LinearLayout>

            <Switch android:id="@+id/swUseCustomJks" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="使用自定义签名" android:layout_marginBottom="8dp"/>
            <Switch android:id="@+id/swAutoSign" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="自动签名" android:layout_marginBottom="8dp"/>
            <Switch android:id="@+id/swDebug" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="调试模式" android:layout_marginBottom="8dp"/>
            <Switch android:id="@+id/swEnableVmpExtract" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="VMP代码抽取" android:layout_marginBottom="8dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginTop="12dp">
                <EditText android:id="@+id/etSavePath" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="保存路径" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etSoName" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="SO文件名称" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etStubClassName" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="壳类名称 (可留空)" android:layout_marginBottom="8dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <Button android:id="@+id/btnClearSavePath" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="清除保存路径" android:layout_marginEnd="4dp"/>
                    <Button android:id="@+id/btnClearStubClassName" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="清除壳类名" android:layout_marginStart="4dp"/>
                </LinearLayout>
                <Button android:id="@+id/btnSaveSettings" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="保存设置" android:layout_marginTop="8dp"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
